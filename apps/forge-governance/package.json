{
  "name": "@sourcea/forge-governance",
  "version": "1.0.0",
  "private": true,
  "description": "Forge governance wrapper — rate_limit, cost_limit, allowed_action",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./service/govern.js": {
      "import": "./dist/service/govern.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/service/govern-cli.js",
    "dev": "tsx watch src/service/govern-cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sourcea/forge-core": "file:../forge-core",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
