      "must_include_any": ["claim", "receipt", "verify", "red flag"],
      "must_not_include_any": ["assume it passed"],
      "format": "audit_trail"
    },
    {
      "id": "chat-unify-prompt-forge",
      "surface": "chat_unify",
      "bucket": "chat_unify_prompt_forge",
      "role": "build",
