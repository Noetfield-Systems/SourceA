      "must_include_any": ["PASS", "BLOCK", "proof", "receipt"],
      "must_not_include_any": ["blind trust", "no proof needed"],
      "format": "verify_act"
    },
    {
      "id": "chat-unify-audit-trail",
      "surface": "chat_unify",
      "bucket": "chat_unify_audit_trail",
      "role": "check",
      "machine": "ord_loop",
