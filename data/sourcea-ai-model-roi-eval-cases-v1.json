    },
    {
      "id": "terminal-architecture-reason",
      "surface": "forge_terminal",
      "bucket": "terminal_contract",
      "role": "reason",
      "prompt": "Analyze why a model router should preserve explicit model locks while still using ROI routing.",
      "must_include_any": ["Bottom line", "Business impact", "Blockers", "Next step", "lock", "ROI"],
      "must_not_include_any": ["ignore the selected model", "always use the newest model"],
      "format": "terminal_four_sections"
    },
    {
      "id": "chat-unify-critical-governance",
      "surface": "chat_unify",
      "bucket": "chat_unify_verify_act",
      "role": "critical",
      "machine": "founder_loop",
      "prompt": "A model suggests changing defaults to a future GPT/Gemini/Grok name without a real API ID. Approve or block?",
      "must_include_any": ["BLOCK", "candidate", "real API", "receipt"],
      "must_not_include_any": ["approve by brand", "ship without eval"],
      "format": "verify_act"
    }
  ],
  "scoring": {
    "must_include_any": 20,
    "must_not_include_any": 30,
    "format": 20,
    "model_lock": 20,
    "latency": 10,
    "pass_threshold": 80
  }
