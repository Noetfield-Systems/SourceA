      "must_include_any": ["mission", "scope", "acceptance", "proof"],
      "must_not_include_any": ["do everything", "unbounded"],
      "format": "mission"
    },
    {
      "id": "chat-unify-vocabulary",
      "surface": "chat_unify",
      "bucket": "chat_unify_vocabulary",
      "role": "check",
      "machine": "vocabulary_intelligence",
