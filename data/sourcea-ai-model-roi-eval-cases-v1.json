      "must_preserve_model_lock": true,
      "must_not_include_any": ["gemini flash-lite fallback"],
      "format": "model_lock"
    },
    {
      "id": "chat-unify-verify-act",
      "surface": "chat_unify",
      "bucket": "chat_unify_verify_act",
      "role": "check",
      "machine": "founder_loop",
