      "must_not_include_any": ["docs/", "config", "repo", "brain-os", "source_path"],
      "format": "boundary_answer"
    },
    {
      "id": "brain-language-general",
      "surface": "brain_chat",
      "bucket": "brain_language",
      "role": "bulk",
      "prompt": "Explain SourceA in Spanish.",
      "must_include_any": ["SourceA"],
      "must_not_include_any": ["English-only", "I can't provide", "Farsi branch", "Spanish branch"],
      "format": "language_answer"
    },
    {
