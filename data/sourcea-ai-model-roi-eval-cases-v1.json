      "surface": "brain_chat",
      "bucket": "brain_public_chat",
      "role": "check",
      "prompt": "What is a live receipt? Give me the link.",
      "must_include_any": ["https://sourcea.app/sourcea/proof/live", "https://sourcea.app/proof/live"],
      "must_not_include_any": ["(Source", "[/sourcea", "docs/"],
      "format": "public_answer"
    },
    {
      "id": "brain-no-internal-doc",
      "surface": "brain_chat",
      "bucket": "brain_guardrails",
