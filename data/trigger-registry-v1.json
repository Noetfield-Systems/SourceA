{
  "schema": "trigger-registry-v1",
  "version": "1.0.5",
  "system": "sourcea",
  "slo": {
    "freshness_target_minutes": 15,
    "success_rate_target": 0.995,
    "latency_target_minutes": 45
  },
  "spec_path": "docs/NOETFIELD_COHERENT_SYSTEM_SPEC_v1.md",
  "law": "L14 T-REG — new trigger requires registry entry in same commit; sweep must pass pre-merge",
  "triggers": [
    {
      "trigger_id": "SA-T1",
      "system": "sourcea",
      "kind": "schedule",
      "schedule": "*/10 * * * *",
      "target": "Railway FBE auto-tick via sourcea-cloud-auto-runtime-tick-v1",
      "valid_in_verified_window": true,
      "owner_workflow": "cloud-forge-run",
      "live_probe": {
        "type": "wrangler_cron",
        "path": "cloud/workers/cloud-auto-runtime-tick-v1/wrangler.toml"
      }
    },
    {
      "trigger_id": "SA-T-loop-specialist",
      "system": "sourcea",
      "kind": "schedule",
      "schedule": "*/15 * * * *",
      "target": "Loop specialist tick → Railway dispatch",
      "valid_in_verified_window": true,
      "owner_workflow": "loop-specialist-tick",
      "live_probe": {
        "type": "wrangler_cron",
        "path": "cloud/workers/loop-specialist-tick-v1/wrangler.toml"
      }
    },
    {
      "trigger_id": "SA-T-signal-factory-piggyback",
      "system": "sourcea",
      "kind": "piggyback",
      "schedule": "*/15 * * * *",
      "target": "Signal factory tick via loop-specialist scheduled() — sole SF trigger (W-LBA-002)",
      "valid_in_verified_window": true,
      "owner_workflow": "signal-factory-tick",
      "parent_trigger_id": "SA-T-loop-specialist",
      "live_probe": {
        "type": "piggyback_hook",
        "path": "cloud/workers/loop-specialist-tick-v1/src/index.js",
        "expects": ["runSignalFactoryTick", "runNerveProbeCycle"]
      }
    },
    {
      "trigger_id": "SA-T-deploy-buyer-surfaces",
      "system": "sourcea",
      "kind": "event",
      "schedule": null,
      "target": "Cloudflare Pages deploy sourcea-com buyer surfaces",
      "valid_in_verified_window": true,
      "owner_workflow": "deploy-sourcea-buyer-surfaces-v1",
      "live_probe": {
        "type": "gha_workflow",
        "path": ".github/workflows/deploy-sourcea-buyer-surfaces-v1.yml",
        "expects": ["push", "workflow_dispatch"]
      }
    },
    {
      "trigger_id": "SA-T4",
      "system": "sourcea",
      "kind": "event",
      "schedule": null,
