  ],
  "default_value_class": "META",
  "cost_estimates_usd_monthly": {
    "cloudflare_worker": 0.35,
    "cloudflare_cron_slot": 0.15,
    "railway_fbe_shared": 18.0,
    "railway_job_amortized": 0.25,
