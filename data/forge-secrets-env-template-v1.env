# SourceA Forge — API keys (copy values to ~/.sina/secrets.env ONLY)
# Saved: 2026-06-25 · NEVER commit real keys in this repo file

# Google Gemini (direct — bulk + check default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenRouter (multi-model router — DeepSeek, Claude via OR)
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_FORGE=
OPENROUTER_API_KEY_EVAL=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Anthropic (direct — best ROI for build/act/check)
ANTHROPIC_API_KEY=

# OpenAI (optional — gpt-4o / o1 reasoning)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
