# Mission B firewall — SourceA root scope only (no upward/sibling scan)
# Match .gitignore heavy dirs + block agent drift outside repo

# --- Block escape from repo root ---
../
../*
~/
~/Library/
~/Desktop/
~/Documents/
~/Downloads/

# --- Archive + receipts (heavy / stale) ---
archive/
archive/attachments/evidence/
archive/sourcea-cleanup-snapshot-*/
archive/sourcea-product-graduation-*/
receipts/
commercial-video-factory/node_modules/
**/node_modules/
commercial-video-factory/out/
data/root-machine/graphify-out/
infra/cleanup/secret-scan-report.txt
**/*-receipt*.json
**/*.jsonl
**/*.log

# --- Generated queues / crawled knowledge / huge local data ---
data/all-remaining-plan-backlog-v1.json
data/cloud-forge-run-queue-active-v1.json
data/secondary-cloud-forge-run-batch-*.json
data/chatbot-knowledge/
data/**/*.sqlite
data/**/*.sqlite3
data/**/*.db
brain-os/plan-registry/sourcea-1000/prompts/
brain-os/plan-registry/sourcea-upgrade-path-7500/
brain-os/plan-registry/sourcea-upgrade-z-continuity-10000/
brain-os/plan-registry/sourcea-upgrade-z2-continuity-10000/

# --- Standard heavy dirs (mirror .gitignore) ---
node_modules/
.venv/
venv/
.turbo/
.next/
dist/
**/dist/
build/
**/build/
.cache/
**/.cache/
.parcel-cache/
coverage/
**/coverage/
.git/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/
*.egg-info/
.supabase/
.DS_Store

# --- Binaries / installers ---
**/*.dmg
**/*.pkg
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
**/*.7z
**/*.iso
**/*.app/Contents/

# --- Secrets (never index) ---
.env
.env.*
**/.env.local
**/.env.*.local
infra/secrets/
.sourcea-secrets/
**/*.pem
**/*.key

# --- Local agent caches ---
.cursor/debug-*.log
.sina-loop/
