#!/usr/bin/env bash
# Install: git config core.hooksPath .githooks
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
changed="$(git diff --cached --name-only --diff-filter=ACM | grep -E '^\.github/workflows/.*\.ya?ml$' || true)"
if [[ -n "$changed" ]]; then
  bash "${ROOT}/scripts/validate-github-workflows-v1.sh"
fi
trigger_changed="$(git diff --cached --name-only --diff-filter=ACM | grep -E \
  '^cloud/workers/.+/wrangler\.toml$|^\.github/workflows/.*\.ya?ml$|^data/trigger-registry-v1\.json$' || true)"
if [[ -n "$trigger_changed" ]]; then
  python3 "${ROOT}/scripts/sandbox_health_sweep_v1.py" --json >/dev/null
fi
gov_changed="$(git diff --cached --name-only --diff-filter=ACM | grep -E \
  '^data/github-automation-governance-v1\.json$|^data/automation-lane-registry-v1\.json$|^data/automation-conflict-matrix-v1\.json$|^data/mission-registry-v1\.json$' || true)"
if [[ -n "$gov_changed" ]]; then
  bash "${ROOT}/scripts/validate-github-automation-governance-v1.sh" >/dev/null
fi
