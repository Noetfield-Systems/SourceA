<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sourcea.dashboard</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>source ~/.zshrc 2>/dev/null; cd /Users/sinakazemnezhad/Desktop/SourceA; python3 scripts/dashboard_server_v1.py</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/sinakazemnezhad/.npm-global/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/sinakazemnezhad</string>
    </dict>

    <!-- Keep alive — restart if it crashes -->
    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/sinakazemnezhad/.sina/dashboard.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/sinakazemnezhad/.sina/dashboard-err.log</string>
</dict>
</plist>
