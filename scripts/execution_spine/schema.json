{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionRecord",
  "description": "Single source of truth for one completed task execution",
  "type": "object",
  "required": [
    "task_id",
    "timestamp",
    "status",
    "stdout",
    "stderr",
    "exit_code",
    "execution_time_ms",
    "input_command",
    "artifact_path",
    "error_signature"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["success", "failed"] },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "exit_code": { "type": "integer" },
    "execution_time_ms": { "type": "integer", "minimum": 0 },
    "input_command": { "type": "string" },
    "artifact_path": { "type": "string" },
    "error_signature": { "type": "string" },
    "action_id": { "type": "string" },
    "producer": { "type": "string" },
    "plan_id": { "type": "string" },
    "queue_status": { "type": "string" }
  }
}
