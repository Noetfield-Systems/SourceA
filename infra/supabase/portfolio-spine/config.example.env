# Supabase — Portfolio Spine (example only — copy to ~/.sourcea-secrets/)

SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) OR new publishable key (sb_publishable_...) — same slot
SUPABASE_ANON_KEY=
# Optional: sb_secret_... for server-only (replaces service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Schema routing — WitnessBC + unified Forge/WTM on SourceA spine (TrustField → noetfield project)
SUPABASE_SCHEMA_GOV=gov
SUPABASE_SCHEMA_WITNESSBC=witnessbc
SUPABASE_SCHEMA_FOUNDATION=foundation
# FORGE FACTORY — unified WTM + Forge + FBE (one brand · one schema)
SUPABASE_SCHEMA_FORGE_FACTORY=forge_factory
SUPABASE_SCHEMA_FORGE=forge_factory
SUPABASE_SCHEMA_WTM=forge_factory
SUPABASE_SCHEMA_AUDIT=audit

# Optional: database password for DDL migrations (scripts/cloud_forge_run_supabase_v1.py --apply-migration)
# Copy infra/supabase/portfolio-spine/config.db.example.env → ~/.sourcea-secrets/portfolio-spine-db.env
# SUPABASE_DB_PASSWORD=

SOURCEA_SUPABASE_TIER=portfolio-spine
